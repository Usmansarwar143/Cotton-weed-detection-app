<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background Gradient -->
    <item android:drawable="@drawable/splash_background" />

    <!-- White Circle background for the icon -->
    <item android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="#F9FAF7"/>
            <size android:width="96dp" android:height="96dp"/>
        </shape>
    </item>

    <!-- Icon: Using Vector Drawable to ensure no background artifacts -->
    <item android:gravity="center" android:top="20dp" android:bottom="20dp" android:left="20dp" android:right="20dp">
        <bitmap android:gravity="center" android:src="@drawable/ic_eco_leaf"/>
    </item>
</layer-list>
